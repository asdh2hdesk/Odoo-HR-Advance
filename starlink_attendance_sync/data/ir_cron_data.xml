<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_starlink_live_refresh" model="ir.cron">
        <field name="name">StarLink: Live exception refresh</field>
        <field name="model_id" ref="model_starlink_sync_log"/>
        <field name="state">code</field>
        <field name="code">env['starlink.sync.engine']._cron_live_refresh()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_starlink_nightly_reconcile" model="ir.cron">
        <field name="name">StarLink: Nightly retro reconciliation</field>
        <field name="model_id" ref="model_starlink_sync_log"/>
        <field name="state">code</field>
        <field name="code">env['starlink.sync.engine']._cron_nightly_reconcile()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=2, minute=15, second=0, microsecond=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_starlink_stale_check" model="ir.cron">
        <field name="name">StarLink: Stale open attendance checker</field>
        <field name="model_id" ref="model_starlink_sync_log"/>
        <field name="state">code</field>
        <field name="code">env['starlink.sync.engine']._cron_stale_check()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="active" eval="True"/>
    </record>

</odoo>
