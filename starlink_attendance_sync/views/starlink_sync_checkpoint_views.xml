<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_starlink_sync_checkpoint_list" model="ir.ui.view">
        <field name="name">starlink.sync.checkpoint.list</field>
        <field name="model">starlink.sync.checkpoint</field>
        <field name="arch" type="xml">
            <list string="Sync Checkpoints">
                <field name="name"/>
                <field name="last_sync_at"/>
                <field name="last_run_at"/>
                <field name="retro_window_start"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_starlink_sync_checkpoint_form" model="ir.ui.view">
        <field name="name">starlink.sync.checkpoint.form</field>
        <field name="model">starlink.sync.checkpoint</field>
        <field name="arch" type="xml">
            <form string="Sync Checkpoint">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="last_sync_at"/>
                            <field name="last_run_at"/>
                            <field name="retro_window_start"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_starlink_sync_checkpoint" model="ir.actions.act_window">
        <field name="name">Checkpoints</field>
        <field name="res_model">starlink.sync.checkpoint</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
