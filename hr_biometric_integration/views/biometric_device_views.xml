<odoo>
    <menuitem id="menu_biometric_root"
              name="Biometric"
              parent="hr.menu_hr_root"
              sequence="99"/>

    <record id="action_biometric_device" model="ir.actions.act_window">
        <field name="name">Biometric Devices</field>
        <field name="res_model">biometric.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_biometric_device"
              name="Devices"
              parent="menu_biometric_root"
              action="action_biometric_device"
              sequence="10"/>

    <record id="view_biometric_device_tree" model="ir.ui.view">
        <field name="name">biometric.device.list</field>
        <field name="model">biometric.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="ip_address"/>
                <field name="device_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_device_form" model="ir.ui.view">
        <field name="name">biometric.device.form</field>
        <field name="model">biometric.device</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button string="Test Connection"
                                type="object"
                                name="action_test_connection"
                                class="btn-primary"/>
                        <button string="Sync Now"
                                type="object"
                                name="sync_device_logs"
                                class="btn-success"/>
                    </header>
                    <group>
                        <field name="name"/>
                        <field name="ip_address"/>
                        <field name="password" password="True"/>
                        <field name="device_type"/>
                        <field name="active"/>
                        <field name="last_sync" readonly="0"/>
                    </group>


                </sheet>
            </form>
        </field>
    </record>
</odoo>