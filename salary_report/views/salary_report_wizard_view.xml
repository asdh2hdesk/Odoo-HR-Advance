<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Salary Report Wizard Form -->
    <record id="view_salary_report_wizard_form" model="ir.ui.view">
        <field name="name">salary.report.wizard.form</field>
        <field name="model">salary.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Salary Report">
                <group>
                    <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_open': True}"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="all_employee"/>
                    <field name="employee_ids"
                           widget="many2many_tags"
                           domain="[('active', '=', True), ('company_id', '=', company_id)]"
                           invisible="all_employee"/>
                    <button name="action_generate_excel"
                            type="object"
                            string="Generate Excel"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Salary Report Action -->
    <record id="action_salary_report_wizard" model="ir.actions.act_window">
        <field name="name">Salary Report</field>
        <field name="res_model">salary.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="groups_id" eval="[(6, 0, [ref('hr_payroll.group_hr_payroll_manager')])]"/>
    </record>

    <menuitem id="menu_salary_report_root"
              name="Salary Report"
              sequence="195"
              web_icon="salary_report,static/description/icon.png"
              groups="hr_payroll.group_hr_payroll_manager"/>

    <!-- Child Menu 1: Salary Report -->
    <menuitem id="menu_salary_report_child"
              name="Salary Report"
              parent="menu_salary_report_root"
              action="action_salary_report_wizard"
              sequence="10"
              groups="hr_payroll.group_hr_payroll_manager"/>

</odoo>
